# Copy to apps/web/.env (see repo root env.example for the full stack layout)
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Browser-visible flags (no secrets)
NEXT_PUBLIC_PAYMENT_PROCESSOR_TYPE=mtn_momo
NEXT_PUBLIC_FEATURE_SUBSCRIPTION_PAYMENT=0

# Next BFF → API (server-side only; not exposed to the browser)
# Local shell: http://127.0.0.1:4000. Docker Compose dev/prod sets http://api:4000 on the `web` service.
API_INTERNAL_URL=http://127.0.0.1:4000
INTERNAL_PROXY_SECRET=change-me-in-dev-use-openssl-rand-hex-32

# Next Server Actions encryption (use the same value at build and runtime in Docker / multi-instance)
# Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
