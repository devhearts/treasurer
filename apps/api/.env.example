# Copy to apps/api/.env (see repo root env.example for shared vars)
# Logging: error | warn | log | info | debug | verbose | silent (default: debug+ in dev, log+ in production)
LOG_LEVEL=debug
# Sentry (optional) — set DSN to enable; leave SENTRY_DEBUG unset (or 0) to avoid SDK log spam in docker logs
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=treasurer@local
# SENTRY_DEBUG=1
PORT=4000
WEB_ORIGIN=http://localhost:3000
INTERNAL_PROXY_SECRET=change-me-use-openssl-rand-hex-32
DATABASE_URL=mysql://treasurer:treasurer@127.0.0.1:3306/treasurer
# Schema: versioned migrations in drizzle/ — `npm run db:migrate` (or Docker db-migrate). For local only, `db:push` syncs schema without new migration files.
# Registration: API expects confirmPassword + Uganda MTN/Airtel phone (normalized to 256…).
# One-time after enabling email verification on an existing DB, run once:
# UPDATE users SET email_verified_at = created_at WHERE email_verified_at IS NULL;
PAYMENT_PROCESSOR_TYPE=mtn_momo
FEATURE_SUBSCRIPTION_PAYMENT=0
NEXT_PUBLIC_APP_URL=http://localhost:3000
# MoMo
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_CURRENCY=UGX
# MoMo disbursement (withdrawals; defaults to collection credentials if unset)
MOMO_DISBURSEMENT_SUBSCRIPTION_KEY=
MOMO_DISBURSEMENT_API_USER=
MOMO_DISBURSEMENT_API_KEY=
# Fees (withdraw quote, event creation subscription)
# MoMo withdraw: tiered bands — MOMO_FEE_PERCENT base (default 4%) + fixed levy per band in wallet-fees.ts
MOMO_FEE_PERCENT=0.04
PLATFORM_FEE_RATE=0.012
EVENT_CREATION_FEE=10000
# Wallet / withdraw (API logs use LOG_LEVEL=debug; MSISDNs redacted in logs)
WITHDRAW_ENABLED=1
WITHDRAW_OTP_TTL_SEC=300
WITHDRAW_OTP_RESEND_SEC=45
# PawaPay (collections + payouts when PAYMENT_PROCESSOR_TYPE=pawapay)
PAWAPAY_API_TOKEN=
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_CURRENCY=UGX
PAWAPAY_COUNTRY=UGA
# RukaPay (collections + payouts when PAYMENT_PROCESSOR_TYPE=rukapay)
RUKAPAY_API_KEY=
RUKAPAY_BASE_URL=https://dev-api.rukapay.net/api/v1/gateway
RUKAPAY_SANDBOX=1
RUKAPAY_CURRENCY=UGX
# With RUKAPAY_SANDBOX=1, validate-beneficiary-sandbox is used (default on; set RUKAPAY_VALIDATE_BENEFICIARY=0 to skip)
# RUKAPAY_VALIDATE_BENEFICIARY=1
# RUKAPAY_CALLBACK_URL=https://api.example.com/webhooks/rukapay
RUKAPAY_WALLET_TYPE=ESCROW
# UAT sign-off CLI: npm run rukapay-uat -w @treasurer/api
# Optional UAT phone overrides: RUKAPAY_UAT_MTN_PHONE, RUKAPAY_UAT_AIRTEL_PHONE
# SMTP (password reset, withdrawal OTP, contribution notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CeremonyWallet <noreply@localhost>
# Account verification submissions (optional; requires SMTP)
SUPPORT_EMAIL=
# Garage (S3-compatible; local Docker: http://localhost:3900, region garage)
GARAGE_ENDPOINT=
GARAGE_REGION=garage
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
GARAGE_BUCKET=
# Africa's Talking
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
