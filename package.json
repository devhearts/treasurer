{
  "name": "treasurer",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "npm run dev -w @treasurer/web",
    "dev:api": "npm run start:dev -w @treasurer/api",
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm run build -w @treasurer/api && npm run build -w @treasurer/web",
    "lint": "npm run lint -w @treasurer/web && npm run lint -w @treasurer/api",
    "typecheck": "npm run typecheck -w @treasurer/web && npm run typecheck -w @treasurer/api",
    "db:push": "npm run db:push -w @treasurer/api",
    "db:migrate": "npm run db:migrate -w @treasurer/api",
    "db:seed": "npm run db:seed -w @treasurer/api",
    "momo:provision": "npm run momo:provision -w @treasurer/web",
    "docker:gen-ports": "node docker/generate-port-envs.mjs",
    "docker:verify-ports": "node docker/verify-ports.mjs",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:up:default": "docker compose --env-file docker/ports.host.default.env up -d",
    "docker:up:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file docker/ports.host.dev.env up -d",
    "docker:up:staging": "docker compose --env-file docker/ports.host.staging.env up -d",
    "docker:up:production": "docker compose --env-file docker/ports.host.production.env up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:db-migrate": "docker compose run --rm db-migrate",
    "docker:db-push": "npm run docker:db-migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "overrides": {
    "rxjs": "7.8.1"
  }
}
