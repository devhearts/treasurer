# syntax=docker/dockerfile:1
# Dev image: full npm install (incl. devDependencies) for `nest start --watch` + `next dev`.
# Source is bind-mounted from the host at runtime (see docker-compose.dev.yml).
# Stage name `runner` matches production compose `build.target` when files are merged.
FROM node:22-alpine AS runner

WORKDIR /repo
COPY package.json package-lock.json ./
COPY apps apps
COPY packages packages

RUN npm ci

WORKDIR /repo
