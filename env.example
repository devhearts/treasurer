# --- Shared / web (Next) — copy to apps/web/.env (see apps/web/.env.example) ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Browser-visible flags (no secrets)
NEXT_PUBLIC_PAYMENT_PROCESSOR_TYPE=mtn_momo
NEXT_PUBLIC_FEATURE_SUBSCRIPTION_PAYMENT=0

# Next BFF → API (server-side only; not exposed to browser)
API_INTERNAL_URL=http://127.0.0.1:4000
INTERNAL_PROXY_SECRET=change-me-in-dev-use-openssl-rand-hex-32

# --- API (Nest) — copy to apps/api/.env ---
# After enabling email verification on an existing DB, run once:
# UPDATE users SET email_verified_at = created_at WHERE email_verified_at IS NULL;
# DATABASE_URL=mysql://treasurer:treasurer@127.0.0.1:3306/treasurer
# WEB_ORIGIN=http://localhost:3000
# INTERNAL_PROXY_SECRET=same-as-above
# PAYMENT_PROCESSOR_TYPE=mtn_momo
# MOMO_* / PAWAPAY_* as needed
# SMTP_HOST= localhost / mailpit
# GARAGE_* S3-compatible
# AFRICASTALKING_USERNAME=
# AFRICASTALKING_API_KEY=

# --- Docker Compose (docker compose up) ---
# Central host ports: docker/ports.base.json + `npm run docker:gen-ports` → docker/ports.host.*.env
# Validate compose / Dockerfiles / garage.toml: `npm run docker:verify-ports`
# Profiles: default (+0), dev (+30), staging (+40), production (+50). See docker/README-ports.md
# npm run docker:up:dev | docker:up:staging | docker:up:production
# Or: docker compose --env-file docker/ports.host.dev.env --env-file .env up --build
#
# Create a `.env` in the repo root for `${VAR}` interpolation and for `api` / `web` `env_file`.
# With a port profile, avoid duplicating WEB_ORIGIN / NEXT_PUBLIC_APP_URL in `.env` unless you override.
#
# INTERNAL_PROXY_SECRET=treasurer-docker-dev-secret
# DB schema: auto on `docker compose up` via `db-migrate` (Drizzle SQL migrations); manual: npm run docker:db-migrate
# Next Server Actions (Docker / multi-instance): set NEXT_SERVER_ACTIONS_ENCRYPTION_KEY to `openssl rand -base64 32` and use the same value at image build and container run; compose provides a dev default.
# Default published ports (no profile): MariaDB :3306, Mailpit :8025 / :1025, Garage S3 :3900 (admin :3903), API :4000, Web :3000
# Optional: GARAGE_ACCESS_KEY / GARAGE_SECRET_KEY / GARAGE_BUCKET (defaults in docker-compose.yml)
